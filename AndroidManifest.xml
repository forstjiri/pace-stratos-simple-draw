<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="cz.kresliciapp"
    android:versionCode="2"
    android:versionName="1.2">

    <uses-sdk
        android:minSdkVersion="22"
        android:targetSdkVersion="22" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="com.huami.watch.launcher.permission.WEAR_LAUNCHER_OPT" />

    <application
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@android:drawable/ic_menu_edit"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <activity
            android:name=".DrawActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.huami.watch.launcher.EXTERNAL_COMMAND.QUICKLAUNCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.huami.watch.launcher.action.SPRING_BOARD_HOST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <meta-data
                android:name="PASSAGER_TARGET"
                android:resource="@array/spring_depend" />
        </activity>

        <receiver
            android:name=".BootReceiver"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
